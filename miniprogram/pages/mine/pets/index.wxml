<view class="container pets-page">
  <view class="pet-card" wx:for="{{pets}}" wx:key="id">
    <image class="pet-avatar" src="{{item.photo_url||defaultAvatar}}" mode="aspectFill" />
    <view class="pet-info">
      <text class="pet-name">{{item.name}}</text>
      <text class="pet-meta">{{item.breed}} {{item.gender==='male'?'♂':(item.gender==='female'?'♀':'')}} {{item.weight?item.weight+'kg':''}}</text>
      <text class="pet-note" wx:if="{{item.notes}}">{{item.notes}}</text>
    </view>
  </view>
  <view class="empty" wx:if="{{pets.length===0}}">
    <text>还没有添加宠物哦</text>
    <view class="add-btn" bindtap="addPet">+ 添加宠物</view>
  </view>
</view>
