.boarding-page { padding-bottom: 160rpx; background: #F9F6F0; min-height: 100vh; }

/* Hero */
.hero { padding: 48rpx 32rpx 40rpx; background: linear-gradient(160deg, #5B8C5A 0%, #4A7A4A 40%, #3D3D3D 100%); position: relative; overflow: hidden; }
.hero::before { content: '🌳'; position: absolute; top: -20rpx; right: -20rpx; font-size: 200rpx; opacity: 0.08; }
.hero::after { content: '🐕'; position: absolute; bottom: -30rpx; left: -20rpx; font-size: 180rpx; opacity: 0.06; }
.hero-bg { position: relative; z-index: 1; }
.hero-tag { display: inline-block; background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.9); padding: 8rpx 24rpx; border-radius: 24rpx; font-size: 24rpx; margin-bottom: 24rpx; }
.hero-title { font-size: 52rpx; font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: 16rpx; }
.hero-sub { font-size: 26rpx; color: rgba(255,255,255,0.75); line-height: 1.5; }

/* VS 对比 */
.vs-card { margin: 32rpx; background: #fff; border-radius: 20rpx; padding: 36rpx 32rpx; display: flex; align-items: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.vs-left, .vs-right { flex: 1; }
.vs-label { display: block; font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.vs-label.vs-bad { color: #999; }
.vs-label.vs-good { color: #5B8C5A; }
.vs-item { display: block; font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.vs-divider { width: 80rpx; text-align: center; font-size: 28rpx; font-weight: 700; color: #E88D2E; flex-shrink: 0; }

/* Section */
.section { margin: 0 32rpx 40rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: #3D3D3D; margin-bottom: 24rpx; }

/* 场景网格 */
.scene-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }
.scene-card { background: #fff; border-radius: 16rpx; padding: 32rpx 24rpx; text-align: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.scene-icon { font-size: 56rpx; margin-bottom: 12rpx; }
.scene-name { font-size: 28rpx; font-weight: 600; color: #3D3D3D; margin-bottom: 8rpx; }
.scene-desc { font-size: 22rpx; color: #999; line-height: 1.4; }

/* 时间线 */
.timeline { background: #fff; border-radius: 16rpx; padding: 32rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.timeline-item { position: relative; padding-left: 40rpx; padding-bottom: 32rpx; border-left: 2rpx solid #E8E4DC; }
.timeline-item:last-child { padding-bottom: 0; border-left: none; }
.timeline-dot { position: absolute; left: -10rpx; top: 6rpx; width: 20rpx; height: 20rpx; border-radius: 50%; background: #E88D2E; }
.timeline-time { font-size: 24rpx; color: #E88D2E; font-weight: 600; margin-bottom: 4rpx; }
.timeline-event { font-size: 30rpx; font-weight: 600; color: #3D3D3D; margin-bottom: 4rpx; }
.timeline-detail { font-size: 24rpx; color: #999; }

/* 价格 */
.price-card { background: #fff; border-radius: 16rpx; padding: 32rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.price-row { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0; border-bottom: 1rpx solid #F5F5F5; }
.price-row:last-child { border-bottom: none; }
.price-row.highlight { background: #FFF9F0; margin: 0 -32rpx; padding: 24rpx 32rpx; border-radius: 0; border-bottom: none; }
.price-name { font-size: 28rpx; color: #3D3D3D; }
.price-value { font-size: 28rpx; font-weight: 700; color: #E88D2E; }
.price-tip { font-size: 22rpx; color: #999; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx dashed #E8E4DC; }

/* 底部栏 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 24rpx 32rpx 48rpx; display: flex; gap: 20rpx; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06); z-index: 100; }
.btn-call { flex: 1; background: #F5F5F5; color: #3D3D3D; border-radius: 44rpx; height: 88rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 600; }
.btn-primary { flex: 1.5; background: #E88D2E; color: #fff; border-radius: 44rpx; height: 88rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 600; box-shadow: 0 4rpx 16rpx rgba(232,141,46,0.3); }
