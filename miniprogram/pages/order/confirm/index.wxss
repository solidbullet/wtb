.confirm-page { padding: 24rpx 24rpx 180rpx; }
.section-title { font-size: 32rpx; font-weight: 600; color: #3D3D3D; margin-bottom: 20rpx; }
.item-list { margin-bottom: 24rpx; }
.item-card { background: #fff; border-radius: 16rpx; padding: 28rpx 32rpx; margin-bottom: 16rpx; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.item-left { flex: 1; min-width: 0; }
.item-name { font-size: 30rpx; color: #3D3D3D; display: block; }
.item-price-wrap { display: flex; align-items: center; margin-top: 8rpx; flex-wrap: wrap; }
.item-price { font-size: 28rpx; color: #E88D2E; font-weight: 600; margin-right: 12rpx; }
.item-price.member-active { color: #5B8C5A; }
.item-origin-price { font-size: 24rpx; color: #bbb; text-decoration: line-through; margin-right: 12rpx; }
.item-saved-tag { font-size: 20rpx; color: #FF4D4D; background: #FFF0F0; padding: 2rpx 8rpx; border-radius: 8rpx; font-weight: 600; }
.item-right { display: flex; align-items: center; gap: 20rpx; }
.item-qty { font-size: 26rpx; color: #999; }
.item-delete { font-size: 24rpx; color: #FF4D4D; padding: 8rpx 16rpx; }

.remark-card { background: #fff; border-radius: 16rpx; padding: 28rpx 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.remark-label { font-size: 30rpx; font-weight: 600; color: #3D3D3D; display: block; margin-bottom: 16rpx; }
.remark-input { font-size: 28rpx; color: #3D3D3D; background: #F9F6F0; padding: 20rpx 24rpx; border-radius: 12rpx; }

.summary-card { background: #fff; border-radius: 16rpx; padding: 28rpx 32rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.summary-row { display: flex; justify-content: space-between; padding: 16rpx 0; font-size: 28rpx; color: #666; }
.summary-row.total { border-top: 2rpx solid #F9F6F0; margin-top: 12rpx; padding-top: 24rpx; font-size: 32rpx; font-weight: 600; color: #3D3D3D; }
.summary-origin { text-decoration: line-through; color: #bbb; }
.summary-saved-label { color: #5B8C5A; }
.summary-saved { color: #5B8C5A; font-weight: 600; }
.total-price { color: #E88D2E; }

.submit-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 140rpx; background: #fff; display: flex; align-items: center; justify-content: space-between; padding: 0 32rpx; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06); z-index: 100; }
.submit-info { display: flex; flex-direction: column; }
.submit-total { font-size: 40rpx; font-weight: 700; color: #E88D2E; }
.submit-tip { font-size: 24rpx; color: #999; }
.submit-btn { background: #E88D2E; color: #fff; padding: 24rpx 56rpx; border-radius: 48rpx; font-size: 30rpx; font-weight: 600; }
.submit-btn.disabled { background: #ccc; }
