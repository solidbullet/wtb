.menu-page { display: flex; flex-direction: column; height: 100vh; background: #F9F6F0; }

/* 桌号提示栏 */
.seat-bar { background: #FFF8F0; padding: 16rpx 32rpx; display: flex; align-items: center; justify-content: space-between; border-bottom: 2rpx solid #F0EDE8; }
.seat-bar.empty { background: #F5F5F5; }
.seat-info { display: flex; align-items: center; }
.seat-icon { font-size: 28rpx; margin-right: 8rpx; }
.seat-name { font-size: 28rpx; font-weight: 600; color: #E88D2E; }
.seat-bar.empty .seat-name { color: #999; }
.seat-change { font-size: 26rpx; color: #E88D2E; border: 2rpx solid #E88D2E; padding: 6rpx 20rpx; border-radius: 24rpx; }

/* 顶部店铺信息 */
.shop-header { background: #fff; padding: 20rpx 32rpx; border-bottom: 2rpx solid #F0EDE8; }
.shop-name { font-size: 32rpx; font-weight: 700; color: #3D3D3D; }
.shop-meta { font-size: 24rpx; color: #999; margin-top: 8rpx; }

/* 主体区域 */
.main-body { flex: 1; display: flex; overflow: hidden; }

/* 左侧分类 */
.category-bar { width: 180rpx; background: #F5F5F5; flex-shrink: 0; height: 100%; }
.category-item { padding: 32rpx 20rpx; font-size: 26rpx; color: #666; text-align: center; position: relative; }
.category-item.active { background: #fff; color: #E88D2E; font-weight: 600; }
.category-item.active::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 6rpx; height: 40rpx; background: #E88D2E; border-radius: 0 4rpx 4rpx 0; }

/* 右侧菜品 */
.dish-list { flex: 1; padding: 0 24rpx; height: 100%; background: #fff; }
.cat-title { font-size: 28rpx; font-weight: 600; color: #3D3D3D; padding: 24rpx 0 16rpx; }
.dish-item { display: flex; padding: 20rpx 0; border-bottom: 2rpx solid #F9F6F0; }
.dish-item:last-child { border-bottom: none; }
.dish-img { width: 160rpx; height: 160rpx; border-radius: 12rpx; flex-shrink: 0; margin-right: 20rpx; background: #eee; }
.dish-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.dish-name { font-size: 30rpx; font-weight: 600; color: #3D3D3D; }
.dish-desc { font-size: 22rpx; color: #999; margin-top: 8rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.dish-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx; }
.price-wrap { display: flex; align-items: center; }
.dish-price { font-size: 32rpx; font-weight: 700; color: #E88D2E; margin-right: 12rpx; }
.dish-price.member-active { color: #5B8C5A; }
.origin-price { font-size: 24rpx; color: #bbb; text-decoration: line-through; }
.qty-control { display: flex; align-items: center; gap: 16rpx; }
.qty-btn { width: 48rpx; height: 48rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 700; }
.qty-btn.minus { background: #F5F5F5; color: #666; border: 2rpx solid #ddd; }
.qty-btn.plus { background: #E88D2E; color: #fff; box-shadow: 0 4rpx 12rpx rgba(232,141,46,0.3); }
.qty-num { font-size: 28rpx; color: #3D3D3D; min-width: 40rpx; text-align: center; font-weight: 600; }
.list-bottom { text-align: center; padding: 40rpx 0; font-size: 24rpx; color: #bbb; }

/* 底部购物车栏 */
.cart-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 120rpx; background: #3D3D3D; display: flex; align-items: center; justify-content: space-between; padding: 0 0 0 24rpx; z-index: 200; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1); }
.cart-left { display: flex; align-items: center; flex: 1; }
.cart-ball { width: 96rpx; height: 96rpx; border-radius: 50%; background: #555; border: 6rpx solid #3D3D3D; display: flex; align-items: center; justify-content: center; position: relative; margin-top: -36rpx; }
.cart-ball.has-goods { background: #E88D2E; }
.ball-icon { font-size: 44rpx; }
.ball-badge { position: absolute; top: -4rpx; right: -4rpx; background: #FF4D4D; color: #fff; font-size: 20rpx; min-width: 36rpx; height: 36rpx; border-radius: 18rpx; text-align: center; line-height: 36rpx; font-weight: 600; }
.cart-price-area { margin-left: 20rpx; display: flex; flex-direction: column; }
.cart-total { font-size: 40rpx; font-weight: 700; color: #fff; }
.cart-total-empty { font-size: 28rpx; color: #999; }
.cart-tip { font-size: 22rpx; color: #999; margin-top: 4rpx; }
.cart-price-sub { display: flex; align-items: center; margin-top: 4rpx; }
.cart-origin { font-size: 22rpx; color: #999; text-decoration: line-through; margin-right: 12rpx; }
.cart-saved { font-size: 22rpx; color: #FF4D4D; font-weight: 600; }
.cart-submit { background: #666; color: #999; padding: 0 48rpx; height: 120rpx; display: flex; align-items: center; font-size: 30rpx; font-weight: 600; }
.cart-submit.active { background: #E88D2E; color: #fff; }

/* 弹层遮罩 */
.panel-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 300; }

/* 购物车弹层 */
.cart-panel { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; border-radius: 32rpx 32rpx 0 0; z-index: 400; transform: translateY(100%); transition: transform 0.3s ease; max-height: 70vh; display: flex; flex-direction: column; }
.cart-panel.show { transform: translateY(0); }
.panel-header { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 32rpx; border-bottom: 2rpx solid #F5F5F5; }
.panel-title { font-size: 30rpx; font-weight: 600; color: #3D3D3D; }
.panel-clear { display: flex; align-items: center; gap: 8rpx; font-size: 26rpx; color: #999; }
.clear-icon { font-size: 28rpx; }
.panel-list { flex: 1; overflow-y: auto; padding: 0 32rpx; max-height: 50vh; }
.panel-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 2rpx solid #F9F6F0; }
.panel-item-left { flex: 1; min-width: 0; }
.panel-item-name { font-size: 28rpx; color: #3D3D3D; display: block; }
.panel-item-price-wrap { display: flex; align-items: center; margin-top: 8rpx; flex-wrap: wrap; }
.panel-item-price { font-size: 26rpx; color: #E88D2E; font-weight: 600; margin-right: 12rpx; }
.panel-item-price.member-active { color: #5B8C5A; }
.panel-origin-price { font-size: 22rpx; color: #bbb; text-decoration: line-through; margin-right: 12rpx; }
.panel-saved-tag { font-size: 20rpx; color: #FF4D4D; background: #FFF0F0; padding: 2rpx 8rpx; border-radius: 8rpx; font-weight: 600; }
.panel-item-right { display: flex; align-items: center; gap: 20rpx; }
.panel-qty-control { display: flex; align-items: center; gap: 16rpx; }
.panel-btn { width: 44rpx; height: 44rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 700; }
.panel-btn.minus { background: #F5F5F5; color: #666; border: 2rpx solid #ddd; }
.panel-btn.plus { background: #E88D2E; color: #fff; }
.panel-qty-num { font-size: 28rpx; color: #3D3D3D; min-width: 36rpx; text-align: center; font-weight: 600; }
.panel-delete { font-size: 24rpx; color: #FF4D4D; padding: 8rpx 16rpx; }
.panel-empty { text-align: center; padding: 60rpx 0; color: #bbb; font-size: 28rpx; }
.panel-footer { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 32rpx; border-top: 2rpx solid #F5F5F5; background: #fff; }
.panel-total { font-size: 28rpx; color: #666; }
.panel-total-price { font-size: 36rpx; font-weight: 700; color: #E88D2E; }
.panel-submit { background: #E88D2E; color: #fff; padding: 20rpx 48rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 600; }
