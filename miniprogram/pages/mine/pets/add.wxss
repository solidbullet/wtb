.add-pet-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.form-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.form-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.label.required::after {
  content: ' *';
  color: #ff4d4f;
}

.input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  box-sizing: border-box;
}

.picker {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.picker.placeholder {
  color: #bbb;
}

.arrow {
  color: #999;
  font-size: 28rpx;
}

/* 照片上传 */
.photo-item {
  display: flex;
  justify-content: center;
}

.photo-wrapper {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f9f9f9;
  border: 2rpx dashed #ddd;
}

.pet-photo {
  width: 100%;
  height: 100%;
}

.photo-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.photo-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.photo-tip {
  font-size: 22rpx;
  color: #999;
}

/* 性别单选 */
.radio-group {
  display: flex;
  gap: 20rpx;
}

.radio {
  flex: 1;
  height: 72rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
}

.radio.active {
  background: #E88D2E;
  color: #fff;
}

/* 文本域 */
.textarea {
  width: 100%;
  height: 240rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* 底部固定提交按钮 */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.submit-btn {
  height: 88rpx;
  background: #E88D2E;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}
