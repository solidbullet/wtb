.recharge-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.recharge-list {
  padding: 20rpx;
}

.recharge-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.recharge-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.recharge-date {
  font-size: 26rpx;
  color: #999;
}

.recharge-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.recharge-status.success {
  color: #52c41a;
  background: #f6ffed;
}

.recharge-status.pending {
  color: #faad14;
  background: #fffbe6;
}

.recharge-status.failed {
  color: #ff4d4f;
  background: #fff1f0;
}

.recharge-card.pending {
  opacity: 0.85;
}

.recharge-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.recharge-row .label {
  font-size: 28rpx;
  color: #666;
}

.recharge-row .value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.recharge-row .value.gift {
  color: #E88D2E;
}

.recharge-row .value.highlight {
  color: #E88D2E;
  font-size: 32rpx;
  font-weight: 600;
}

.recharge-row .value.channel {
  color: #999;
  font-size: 26rpx;
}

.recharge-row.total {
  margin-top: 10rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #f0f0f0;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #bbb;
}
