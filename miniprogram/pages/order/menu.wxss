.menu-page { background: #F9F6F0; min-height: 100vh; display: flex; flex-direction: column; }

/* 桌号提示栏 */
.seat-bar { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 30rpx; background: #fff; border-bottom: 2rpx solid #F5F5F5; }
.seat-bar.empty { background: #FFF8F0; }
.seat-info { display: flex; align-items: center; gap: 12rpx; }
.seat-icon { font-size: 32rpx; }
.seat-name { font-size: 28rpx; color: #3D3D3D; font-weight: 500; }
.seat-change { font-size: 26rpx; color: #E88D2E; padding: 8rpx 20rpx; border: 2rpx solid #E88D2E; border-radius: 28rpx; }

/* 店铺信息 */
.shop-header { padding: 24rpx 30rpx; background: #fff; }
.shop-name { font-size: 32rpx; font-weight: 700; color: #3D3D3D; }
.shop-meta { font-size: 24rpx; color: #999; margin-top: 8rpx; }

/* 主体区域 */
.main-body { display: flex; flex: 1; overflow: hidden; }

/* 左侧分类 */
.category-bar { width: 180rpx; background: #F9F6F0; height: 100%; }
.category-item { padding: 28rpx 16rpx; text-align: center; font-size: 26rpx; color: #666; border-left: 6rpx solid transparent; }
.category-item.active { background: #fff; color: #E88D2E; font-weight: 600; border-left-color: #E88D2E; }

/* 右侧菜品 */
.dish-list { flex: 1; background: #fff; height: 100%; padding: 0 24rpx; }
.cat-title { font-size: 28rpx; font-weight: 600; color: #3D3D3D; padding: 24rpx 0 16rpx; }
.dish-item { display: flex; gap: 20rpx; padding: 20rpx 0; border-bottom: 2rpx solid #F9F6F0; }
.dish-img { width: 160rpx; height: 160rpx; border-radius: 16rpx; background: #F5F5F5; flex-shrink: 0; }
.dish-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.dish-name { font-size: 30rpx; font-weight: 600; color: #3D3D3D; }
.dish-desc { font-size: 24rpx; color: #999; margin-top: 8rpx; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.dish-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 12rpx; }
.price-wrap { display: flex; align-items: center; gap: 12rpx; }
.dish-price { font-size: 32rpx; font-weight: 700; color: #E88D2E; }
.dish-price.member-active { color: #5B8C5A; }
.origin-price { font-size: 24rpx; color: #bbb; text-decoration: line-through; }
.qty-control { display: flex; align-items: center; gap: 16rpx; }
.qty-btn { width: 48rpx; height: 48rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 700; }
.qty-btn.minus { background: #F5F5F5; color: #666; border: 2rpx solid #ddd; }
.qty-btn.plus { background: #E88D2E; color: #fff; }
.qty-num { font-size: 30rpx; color: #3D3D3D; min-width: 40rpx; text-align: center; font-weight: 600; }
.list-bottom { text-align: center; padding: 40rpx 0; color: #bbb; font-size: 26rpx; }

/* 底部购物车 */
.cart-bar { position: fixed; left: 24rpx; right: 24rpx; bottom: 24rpx; background: #3D3D3D; border-radius: 48rpx; display: flex; justify-content: space-between; align-items: center; padding: 16rpx 24rpx; z-index: 500; box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15); }
.cart-left { display: flex; align-items: center; gap: 20rpx; flex: 1; }
.cart-ball { width: 72rpx; height: 72rpx; border-radius: 50%; background: #555; display: flex; align-items: center; justify-content: center; position: relative; }
.cart-ball.has-goods { background: #E88D2E; }
.ball-icon { font-size: 36rpx; }
.ball-badge { position: absolute; top: -8rpx; right: -8rpx; background: #FF4D4D; color: #fff; font-size: 20rpx; min-width: 32rpx; height: 32rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 600; }
.cart-price-area { display: flex; flex-direction: column; }
.cart-total { font-size: 36rpx; font-weight: 700; color: #fff; }
.cart-price-sub { display: flex; align-items: center; gap: 12rpx; margin-top: 4rpx; }
.cart-origin { font-size: 24rpx; color: #aaa; text-decoration: line-through; }
.cart-saved { font-size: 22rpx; color: #FF4D4D; }
.cart-submit { background: #E88D2E; color: #fff; padding: 20rpx 40rpx; border-radius: 36rpx; font-size: 28rpx; font-weight: 600; }
.cart-submit.active { background: #E88D2E; }

/* 购物车弹层遮罩 */
.panel-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 300; }

/* 购物车弹层 */
.cart-panel { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; border-radius: 32rpx 32rpx 0 0; z-index: 400; transform: translateY(100%); transition: transform 0.3s ease; max-height: 70vh; display: flex; flex-direction: column; }
.cart-panel.show { transform: translateY(0); }
.panel-header { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 32rpx; border-bottom: 2rpx solid #F5F5F5; }
.panel-title { font-size: 30rpx; font-weight: 600; color: #3D3D3D; }
.panel-clear { display: flex; align-items: center; gap: 8rpx; font-size: 26rpx; color: #999; }
.clear-icon { font-size: 28rpx; }
.panel-list { flex: 1; overflow-y: auto; padding: 0 32rpx; max-height: 50vh; }
.panel-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 2rpx solid #F9F6F0; }
.panel-item-left { flex: 1; min-width: 0; }
.panel-item-name { font-size: 28rpx; color: #3D3D3D; display: block; }
.panel-item-price-wrap { display: flex; align-items: center; margin-top: 8rpx; flex-wrap: wrap; }
.panel-item-price { font-size: 26rpx; color: #E88D2E; font-weight: 600; margin-right: 12rpx; }
.panel-item-price.member-active { color: #5B8C5A; }
.panel-origin-price { font-size: 22rpx; color: #bbb; text-decoration: line-through; margin-right: 12rpx; }
.panel-saved-tag { font-size: 20rpx; color: #FF4D4D; background: #FFF0F0; padding: 2rpx 8rpx; border-radius: 8rpx; font-weight: 600; }
.panel-item-right { display: flex; align-items: center; gap: 20rpx; }
.panel-qty-control { display: flex; align-items: center; gap: 16rpx; }
.panel-btn { width: 44rpx; height: 44rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 700; }
.panel-btn.minus { background: #F5F5F5; color: #666; border: 2rpx solid #ddd; }
.panel-btn.plus { background: #E88D2E; color: #fff; }
.panel-qty-num { font-size: 28rpx; color: #3D3D3D; min-width: 36rpx; text-align: center; font-weight: 600; }
.panel-delete { font-size: 24rpx; color: #FF4D4D; padding: 8rpx 16rpx; }
.panel-empty { text-align: center; padding: 60rpx 0; color: #bbb; font-size: 28rpx; }
.panel-footer { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 32rpx; border-top: 2rpx solid #F5F5F5; background: #fff; }
.panel-total { font-size: 28rpx; color: #666; }
.panel-total-price { font-size: 36rpx; font-weight: 700; color: #E88D2E; }
.panel-submit { background: #E88D2E; color: #fff; padding: 20rpx 48rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 600; }

/* 桌号选择弹窗 */
.seat-picker-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 600; }
.seat-picker { position: fixed; left: 60rpx; right: 60rpx; top: 50%; transform: translateY(-50%) scale(0.95); background: #fff; border-radius: 24rpx; z-index: 700; padding: 40rpx; opacity: 0; transition: all 0.3s ease; pointer-events: none; }
.seat-picker.show { transform: translateY(-50%) scale(1); opacity: 1; pointer-events: auto; }
.picker-header { text-align: center; margin-bottom: 32rpx; }
.picker-title { font-size: 36rpx; font-weight: 700; color: #3D3D3D; display: block; }
.picker-sub { font-size: 26rpx; color: #999; margin-top: 12rpx; display: block; }
.picker-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20rpx; margin-bottom: 32rpx; }
.picker-item { background: #F9F6F0; border-radius: 16rpx; padding: 28rpx 0; text-align: center; font-size: 32rpx; font-weight: 600; color: #3D3D3D; border: 2rpx solid transparent; }
.picker-item:active { background: #E88D2E; color: #fff; }
.picker-custom { display: flex; gap: 16rpx; align-items: center; }
.picker-input { flex: 1; background: #F9F6F0; border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 28rpx; color: #3D3D3D; }
.picker-btn { background: #E88D2E; color: #fff; padding: 20rpx 40rpx; border-radius: 16rpx; font-size: 28rpx; font-weight: 600; }
